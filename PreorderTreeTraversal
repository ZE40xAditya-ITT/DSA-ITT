class tree:
    def __init__(self, data):
        self.data = data
        self.left = None
        self.right = None

def preorder_traversal(root):
    if root is None:
        return []
    left = preorder_traversal(root.left)
    right = preorder_traversal(root.right)
    return [root.data] + left + right

tree_root = tree(1)
tree_root.left = tree(2)
tree_root.right = tree(3)
tree_root.left.left = tree(4)
print(preorder_traversal(tree_root))
